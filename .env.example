# WhatsApp Bot environment variables
# Copy this file to .env and fill in your actual values

# Server Configuration
# Port for health check server (Render will set this automatically)
PORT=3000

# Authentication folder path (for storing WhatsApp session data)
AUTH_FOLDER=./auth_info

# MongoDB connection string
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/?appName=YourApp
# For local MongoDB: mongodb://localhost:27017
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=YourApp
MONGO_DB=whatsapp-bot

# Business Configuration (for multi-tenant support)
BUSINESS_ID=default-business
BUSINESS_NAME=My Business
OWNER_JID=254712310100@s.whatsapp.net

# Bot Settings
# Time to send daily quotes (24-hour format)
QUOTE_TIME=08:00

# Quiet hours - no autoreplies during this window (24-hour format)
QUIET_WINDOW_START=22:00
QUIET_WINDOW_END=08:00

# Cooldown period between autoreplies to the same user (in seconds)
REPLY_COOLDOWN_SECONDS=60

# Log file path
LOG_FILE=./logs/bot.log
